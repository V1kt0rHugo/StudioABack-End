// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

model Client {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  password         String
  CustomerServices CustomerService[]
}

model Employee {
  id                   String              @id @default(uuid())
  name                 String
  email                String              @unique
  password             String
  CPF                  String              @unique
  phone                String
  commissionPercentage Float
  PerformedServices    PerformedServices[]
  Skills               Services[]          @relation("EmployeeSkills")
  Schedules            EmployeeSchedule[]
}

model CustomerService {
  id                String              @id @default(uuid())
  idClient          String
  Client            Client              @relation(fields: [idClient], references: [id])
  Status            ServiceStatus       @default(SCHEDULED)
  Date              DateTime
  TotalValue        Float
  ConsumedItems     ConsumedItems[]
  PerformedServices PerformedServices[]
}

model Products {
  id            String          @id @default(uuid())
  name          String
  price         Float
  brand         String
  stock         Int
  ConsumedItems ConsumedItems[]
}

model Services {
  id                String              @id @default(uuid())
  name              String
  price             Float
  PerformedServices PerformedServices[]
  SkilledEmployees  Employee[]          @relation("EmployeeSkills")
}

model PerformedServices {
  id                   String          @id @default(uuid())
  idCustomerService    String
  CustomerService      CustomerService @relation(fields: [idCustomerService], references: [id])
  idService            String
  Service              Services        @relation(fields: [idService], references: [id])
  idEmployee           String
  Employee             Employee        @relation(fields: [idEmployee], references: [id])
  priceCharged         Float
  commissionPercentage Float
  commissionValue      Float
}

model ConsumedItems {
  id                String          @id @default(uuid())
  idCustomerService String
  CustomerService   CustomerService @relation(fields: [idCustomerService], references: [id])
  idProduct         String
  Products          Products        @relation(fields: [idProduct], references: [id])
  usedQuantity      Int
}

model EmployeeSchedule {
  id         String   @id @default(uuid())
  employeeId String
  Employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int      
  startTime  String   
  endTime    String   
}
