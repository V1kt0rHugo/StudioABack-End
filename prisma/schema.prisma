// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  password         String
  CustomerServices CustomerService[]
}

model Employee {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  password         String
  CPF              String            @unique
  phone            String
  CustomerServices CustomerService[]
}

model CustomerService {
  id            String          @id @default(uuid())
  idClient      String
  Client        Client          @relation(fields: [idClient], references: [id])
  idEmployee    String
  Employee      Employee        @relation(fields: [idEmployee], references: [id])
  Date          DateTime
  TotalValue    Float
  ConsumedItems ConsumedItems[]
}

model Products {
  id            String          @id @default(uuid())
  name          String
  price         Float
  brand         String
  stock         Int
  ConsumedItems ConsumedItems[]
}

model Services {
  id                   String @id @default(uuid())
  name                 String
  price                Float
  commissionPercentage Float
}

model ConsumedItems {
  id                String          @id @default(uuid())
  idCustomerService String
  CustomerService   CustomerService @relation(fields: [idCustomerService], references: [id])
  idProduct         String
  Products          Products        @relation(fields: [idProduct], references: [id])
  usedQuantity      Int
}
